# Railway sets DATABASE_URL automatically when you link a Postgres database
# to this service. For local testing, point it at your own local Postgres:
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/nursery_test
PORT=3000

# Required for login sessions to be secure. Generate any long random string,
# e.g. run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-string
